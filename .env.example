# ============================================================
#  HSI Employee Engagement Platform — Environment Template
#
#  USAGE
#    cp .env.example .env
#    Edit .env with your real values
#    ./setup.sh          ← docker-compose production stack
#
#  Both the backend and frontend read from this single file.
#  Never commit .env to version control.
# ============================================================


# ── Database ─────────────────────────────────────────────────────────────────
# Credentials used by PostgreSQL, pgBouncer and the backend API.
DB_NAME="hsi_portal"
DB_USER="hsi_user"
DB_PASSWORD="change-this-strong-db-password"

# Full connection string for the backend (points to pgBouncer in production,
# localhost:5432 for local dev without Docker).
DATABASE_URL="postgresql://hsi_user:change-this-strong-db-password@localhost:5432/hsi_portal"


# ── Security ─────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-32-char-string"
JWT_REFRESH_SECRET="change-me-to-a-different-random-32-char-string"

# Bcrypt cost factor (10–14 recommended; higher = slower but safer)
BCRYPT_ROUNDS="12"

# Only email addresses from this domain can register
ALLOWED_DOMAIN="hitachi-systems.com"


# ── Token TTLs ────────────────────────────────────────────────────────────────
# Access token expiry (minutes)
ACCESS_TTL_MIN="15"

# Refresh token expiry (days)
REFRESH_TTL_DAY="30"


# ── Account lockout ───────────────────────────────────────────────────────────
# Consecutive failed logins before temporary lockout
LOCKOUT_FAILS="5"

# Lockout duration (minutes)
LOCKOUT_MIN="15"


# ── MFA / OTP ─────────────────────────────────────────────────────────────────
# Set to true to require email OTP on every login
MFA_ENABLED="true"

# OTP digit length
OTP_LENGTH="6"

# OTP expiry (minutes)
OTP_TTL_MIN="10"

# Max OTP attempts before code is invalidated
OTP_MAX_ATTEMPTS="3"

# Fixed OTP accepted for seeded demo accounts — set to "" in production
DEMO_OTP="000000"


# ── Admin seed account ────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@hitachi-systems.com"
ADMIN_PASSWORD="Admin@123"


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for local dev only.
CORS_ORIGINS="*"

#
# ── File uploads ──────────────────────────────────────────────────────────────
# Max file size in bytes (default 10 MB)
MAX_UPLOAD_BYTES="10485760"

# Local fallback upload directory (used when MinIO is unavailable)
LOCAL_UPLOADS_DIR="/tmp/hsi_uploads"


# ── MinIO / S3-compatible object storage ──────────────────────────────────────
# Host:port of your MinIO instance (no http/https prefix)
MINIO_ENDPOINT="minio:9000"

MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"

# Bucket name — auto-created on first start if missing
MINIO_BUCKET="hsi-eep"

# Set to true if MinIO is behind HTTPS
MINIO_SECURE="false"

# Public base URL for uploaded files (leave empty to auto-derive)
MINIO_PUBLIC_URL=""


# ── AWS SES (transactional email / OTP delivery) ──────────────────────────────
# Leave blank to use DEV fallback — OTPs are logged to stdout instead.
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SES_SENDER_EMAIL="noreply@hitachi-systems.com"
SES_SENDER_NAME="HSI Enterprise Platform"


# ── Redis (WebSocket pub/sub & rate limiting) ─────────────────────────────────
# Leave empty to use in-memory fallback (single-instance only).
# Docker Compose sets this to redis://redis:6379/0 automatically.
REDIS_URL=""

# WebSocket broadcast channel name
WS_BROADCAST_CHANNEL="hsi:broadcast"


# ── pgBouncer connection pooler ───────────────────────────────────────────────
PGBOUNCER_POOL_MODE="transaction"
PGBOUNCER_MAX_CLIENT_CONN="500"
PGBOUNCER_DEFAULT_POOL_SIZE="20"
PGBOUNCER_MIN_POOL_SIZE="5"
PGBOUNCER_RESERVE_POOL_SIZE="10"
PGBOUNCER_RESERVE_POOL_TIMEOUT="3"


# ── Backend server ────────────────────────────────────────────────────────────
UVICORN_WORKERS="2"
UVICORN_LOG_LEVEL="info"


# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=""
SENTRY_TRACES_RATE="0.1"


# ── App metadata ──────────────────────────────────────────────────────────────
ENVIRONMENT="production"
APP_VERSION="sprint-g"


# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend API — used by the React build and browser clients.
# Must be the full HTTPS URL visible to end-users, e.g. https://portal.your-domain.com
REACT_APP_BACKEND_URL="https://portal.your-domain.com"

# Nginx port bindings
HTTP_PORT="80"
HTTPS_PORT="443"
